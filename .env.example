# ==============================================================================
# API Keys & LLM Configuration
# ==============================================================================
# Set your preferred LLM provider here (openai, anthropic, google_genai, etc.)
#OPENAI_API_KEY="your_openai_api_key_here"
# ANTHROPIC_API_KEY="your_anthropic_api_key_here"
GOOGLE_API_KEY="your-gemini-api-key"
GOOGLE_GENAI_USE_VERTEXAI="true" # make it true if you are planning to use vertex ai

LLM_PROVIDER="google_genai"
LLM_MODEL="gemini-3.1-flash-lite-preview"


# ── LLM: Higher-tier (Planner & Supervisor routing) ──
LLM_HIGHER_PROVIDER="google_genai"
LLM_HIGHER_MODEL="gemini-3.1-pro-preview"


# ── LLM: DeepAgent (Coordinator & multi-step coding generation) ──
LLM_DEEPAGENT_PROVIDER="google_genai"
LLM_DEEPAGENT_MODEL="gemini-3.1-pro-preview"


# ==============================================================================
# GitHub Configuration (For github-agent)
# ==============================================================================
GITHUB_PERSONAL_ACCESS_TOKEN="your_github_pat_with_repo_scope"
GITHUB_MCP_URL="https://api.githubcopilot.com/mcp"

A2A_SERVER_PORT=10102
# ==============================================================================
# Agent & MCP Configuration
# ==============================================================================
LOG_LEVEL=INFO
HELM_WORKSPACE=./workspace/helm-charts
MCP_PATH=/mcp

# ==============================================================================
# ArgoCD Integration
# ==============================================================================
ARGOCD_SERVER_URL=https://host.docker.internal:9090
ARGOCD_AUTH_TOKEN="your_argocd_auth_token_here"
ARGOCD_INSECURE=true

# ==============================================================================
# Observability — Prometheus MCP Server
# ==============================================================================
# These env vars are inherited by the prometheus-mcp-server stdio subprocess.
PROMETHEUS_BASE_URL=http://localhost:9090
PROMETHEUS_VERIFY_SSL=false
PROMETHEUS_BACKEND_ID=default
PROMETHEUS_TYPE=prometheus

# ==============================================================================
# Observability — Alertmanager MCP Server
# ==============================================================================
# These env vars are inherited by the alertmanager-mcp-server stdio subprocess.
ALERTMANAGER_BASE_URL=http://localhost:9093
ALERTMANAGER_VERIFY_SSL=false
ALERTMANAGER_BACKEND_ID=default

# Silence safety guardrails
AM_MAX_SILENCE_MINUTES=1440
AM_SILENCE_WARNING_THRESHOLD=50

# ==============================================================================
# Observability (LangSmith)
# ==============================================================================
# Disable background callbacks to prevent GeneratorExit errors during streaming
LANGCHAIN_CALLBACKS_BACKGROUND=false
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY="your_langsmith_api_key_here"
LANGSMITH_PROJECT="k8s-autopilot"